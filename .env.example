# Copy to .env and fill in. .env is gitignored — never commit real keys.

# ---- Server ----
PORT=8090
# Comma-separated origins allowed to call the API (the website(s) that embed the widget)
ALLOWED_ORIGINS=https://gmic.ai,https://www.gmic.ai

# ---- STT: Groq Whisper ----
GROQ_API_KEY=
STT_MODEL=whisper-large-v3

# ---- LLM: OpenAI (swappable) ----
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# ---- Slack (P0: Luna creates the app, fills these) ----
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#gmic-web-voice-leads

# ---- Memory management (see DESIGN.md §Memory) ----
SESSION_TTL_SECONDS=1800      # idle session eviction (30 min)
MAX_TURNS_IN_MEMORY=20        # per-session turn cap kept in RAM
MAX_SESSIONS=500              # global cap; LRU-evict beyond this
LLM_HISTORY_TURNS=8           # sliding window sent to the LLM each turn
MAX_AUDIO_SECONDS=90          # reject longer voice clips
